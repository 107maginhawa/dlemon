{
  "include": ["apps/dentalemon/src/**/*.{ts,tsx}"],
  "exclude_patterns": [
    "**/generated/**",
    "**/vendor/**",
    "**/__mocks__/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/tests/**",
    "**/routeTree.gen.ts",
    "**/*.gen.ts"
  ],
  "module_roots": ["apps/dentalemon/src"],
  "module_depth": 1,
  "plugins": ["react", "tanstack"],
  "sdk_import_specifiers": ["@monobase/sdk-ts"],
  "confidence_threshold": "MEDIUM",
  "out_dir": "docs/audits/codebase-map"
}
