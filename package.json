{
  "name": "monobase-healthcare",
  "version": "0.1.0.1",
  "private": true,
  "description": "Monobase Healthcare Application Platform - Universal Healthcare API",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "specs/*"
  ],
  "packageManager": "bun@1.2.21",
  "scripts": {
    "build": "bun run --filter '*' build",
    "clean": "rm -rf node_modules bun.lock && find . -name 'node_modules' -type d -prune -exec rm -rf {} +",
    "seed": "bun scripts/seed-demo.ts",
    "db:reset": "bun scripts/reset-db.ts",
    "db:reseed": "bun scripts/reset-db.ts && bun scripts/seed-demo.ts && (cd services/api-ts && bun scripts/seed-supplement.ts)",
    "test:contract": "bun scripts/run-contract-tests.ts",
    "test:contract:fuzz": "bun scripts/run-schemathesis.ts",
    "typecheck": "bun run --filter dentalemon typecheck",
    "lint": "bun run --filter dentalemon lint",
    "test": "bun run --filter dentalemon test",
    "test:e2e": "bun run --filter dentalemon test:e2e",
    "audit:trace": "bun scripts/audit-traceability.ts",
    "audit:trace:ci": "bun scripts/audit-traceability.ts --ci"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.2.21"
  },
  "overrides": {
    "esbuild": "0.27.7",
    "axios": ">=1.16.0"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "0.27.7",
    "@esbuild/linux-x64": "0.27.7",
    "@happy-dom/global-registrator": "^20.9.0",
    "@rollup/rollup-darwin-arm64": "^4.52.3",
    "@rollup/rollup-linux-x64-gnu": "^4.52.3",
    "@tauri-apps/cli-darwin-arm64": "^2.10.1",
    "@tauri-apps/cli-linux-x64-gnu": "^2.10.1",
    "pg-cloudflare": "^1.2.7",
    "playwright": "^1.59.1"
  }
}
