{
  "name": "monobase-healthcare",
  "version": "0.1.0.1",
  "private": true,
  "description": "Monobase Healthcare Application Platform - Universal Healthcare API",
  "type": "module",
  "workspaces": [
    "apps/account",
    "apps/dentalemon",
    "apps/sample-workspace",
    "packages/*",
    "services/*",
    "specs/*"
  ],
  "packageManager": "bun@1.2.21",
  "scripts": {
    "build": "bun run --filter '*' build",
    "clean": "rm -rf node_modules bun.lock && find . -name 'node_modules' -type d -prune -exec rm -rf {} +",
    "seed": "bun scripts/seed-demo.ts",
    "dev:doctor": "bun run --filter '@monobase/api-ts' dev:doctor",
    "db:reset": "bun scripts/reset-db.ts",
    "db:reseed": "bun scripts/reset-db.ts && bun scripts/seed-demo.ts && (cd services/api-ts && bun scripts/seed-supplement.ts)",
    "test:contract": "bun scripts/run-contract-tests.ts",
    "test:contract:fuzz": "bun scripts/run-schemathesis.ts",
    "test:contract:fuzz:blocking": "SCHEMATHESIS_CHECKS=not_a_server_error,status_code_conformance SCHEMATHESIS_MAX_EXAMPLES=10 SCHEMATHESIS_SUPPRESS_HEALTH_CHECK=all bun scripts/run-schemathesis.ts",
    "verify:app": "bun scripts/verify-app.ts",
    "verify:app:ci": "bun scripts/verify-app.ts --ci",
    "verify:app:strict": "bun scripts/verify-app.ts --ci --require-stack",
    "verify:app:deep": "bun scripts/verify-app.ts --ci --deep",
    "infra:up": "docker compose -f services/api-ts/docker-compose.deps.yml up -d --wait",
    "infra:down": "docker compose -f services/api-ts/docker-compose.deps.yml down",
    "infra:reset": "docker compose -f services/api-ts/docker-compose.deps.yml down -v && docker compose -f services/api-ts/docker-compose.deps.yml up -d --wait",
    "infra:logs": "docker compose -f services/api-ts/docker-compose.deps.yml logs -f",
    "typecheck": "bun run --filter dentalemon --filter '@monobase/api-ts' typecheck",
    "lint": "bun run --filter dentalemon --filter '@monobase/api-ts' lint && bun run check:fsm-tokens && bun run check:font-size",
    "check:fsm-tokens": "bun scripts/check-fsm-tokens.ts",
    "check:font-size": "bun scripts/check-arbitrary-font-size.ts",
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "bun run --filter dentalemon test",
    "test:e2e": "bun run --filter dentalemon test:e2e",
    "turbo:typecheck": "turbo run typecheck --filter=dentalemon --filter=@monobase/api-ts",
    "turbo:lint": "turbo run lint --filter=dentalemon --filter=@monobase/api-ts",
    "turbo:test": "turbo run test --filter=dentalemon --filter=@monobase/api-ts",
    "audit:rust": "bash scripts/cargo-audit.sh",
    "audit:trace": "bun scripts/audit-traceability.ts",
    "audit:trace:ci": "bun scripts/audit-traceability.ts --ci",
    "check:secret-logging": "bun scripts/check-secret-logging.ts",
    "check:kg-freshness": "bun scripts/check-kg-freshness.ts",
    "check:kg-review": "bun scripts/kg-review-radar.ts",
    "coverage:roles": "bun scripts/coverage/role-op-matrix.ts",
    "coverage:roles:ci": "bun scripts/coverage/role-op-matrix.ts --check",
    "coverage:endpoints": "bun scripts/coverage/endpoint-matrix.ts",
    "coverage:br": "bun scripts/coverage/br-matrix.ts",
    "coverage:fsm": "bun scripts/coverage/fsm-matrix.ts",
    "coverage:workflows": "bun scripts/coverage/workflow-matrix.ts",
    "coverage:fe-route": "bun scripts/coverage/fe-route-matrix.ts",
    "coverage:all": "bun scripts/coverage/run-all.ts",
    "coverage:all:ci": "bun scripts/coverage/run-all.ts --check"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.2.21"
  },
  "overrides": {
    "esbuild": "0.27.7",
    "axios": ">=1.16.0",
    "fast-uri": ">=3.1.2",
    "uuid": ">=11.1.1",
    "fast-xml-builder": ">=1.1.7",
    "dompurify": ">=3.4.0",
    "qs": ">=6.15.2",
    "brace-expansion": "2.1.0",
    "ws": ">=8.20.1"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "0.27.7",
    "@esbuild/linux-x64": "0.27.7",
    "@happy-dom/global-registrator": "^20.9.0",
    "@rollup/rollup-darwin-arm64": "^4.52.3",
    "@rollup/rollup-linux-x64-gnu": "^4.52.3",
    "@tauri-apps/cli-darwin-arm64": "^2.10.1",
    "@tauri-apps/cli-linux-x64-gnu": "^2.10.1",
    "pg-cloudflare": "^1.2.7",
    "playwright": "^1.59.1",
    "turbo": "^2"
  }
}
