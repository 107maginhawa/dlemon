{
  "name": "dentalemon",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/shyim/devcontainers-features/bun:0": {}
  },
  "forwardPorts": [3003, 7213, 5432, 9000, 9001, 8025],
  "portsAttributes": {
    "3003": { "label": "web (dentalemon)" },
    "7213": { "label": "api (api-ts)" },
    "5432": { "label": "postgres" },
    "9000": { "label": "minio (s3)" },
    "9001": { "label": "minio console" },
    "8025": { "label": "mailpit" }
  },
  "postCreateCommand": "bun install && bun run infra:up"
}
