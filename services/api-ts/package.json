{
  "name": "@monobase/api-ts",
  "version": "0.2.0.0",
  "description": "Monobase Application Platform API Service",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./core/config": "./src/core/config.ts",
    "./core/database": "./src/core/database.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "dev:deps:up": "docker compose -f docker-compose.deps.yml up -d --wait",
    "dev:deps:down": "docker compose -f docker-compose.deps.yml down -v",
    "build": "bun build --compile --minify --sourcemap --external ajv --external ajv-draft-04 src/index.ts --outfile dist/server",
    "generate": "bun scripts/generate.ts && bun scripts/verify-registry-uniqueness.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:setup:test": "createdb -h localhost -U postgres monobase_test 2>/dev/null || true && DATABASE_URL=postgresql://postgres:password@localhost:5432/monobase_test drizzle-kit migrate",
    "test": "bun run scripts/test-with-db.ts",
    "test:unit": "bun run scripts/test-with-db.ts",
    "test:coverage": "bun run scripts/test-with-db.ts --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:migrations": "bun scripts/lint-migrations.ts",
    "check:duplicate-ops": "bun scripts/check-duplicate-operation-ids.ts",
    "check:boundaries": "bun scripts/check-module-boundaries.ts",
    "check:boundaries:error": "bun scripts/check-module-boundaries.ts --error",
    "check:boundaries:dental-billing": "bun scripts/check-module-boundaries.ts --error --module dental-billing",
    "check:boundaries:dental-perio": "bun scripts/check-module-boundaries.ts --error --module dental-perio",
    "check:boundaries:dental-org": "bun scripts/check-module-boundaries.ts --error --module dental-org",
    "check:boundaries:dental-visit": "bun scripts/check-module-boundaries.ts --error --module dental-visit",
    "check:boundaries:dental-scheduling": "bun scripts/check-module-boundaries.ts --error --module dental-scheduling",
    "check:boundaries:dental-clinical": "bun scripts/check-module-boundaries.ts --error --module dental-clinical",
    "check:boundaries:dental-pmd": "bun scripts/check-module-boundaries.ts --error --module dental-pmd",
    "check:boundaries:dental-patient": "bun scripts/check-module-boundaries.ts --error --module dental-patient",
    "check:boundaries:dental-imaging": "bun scripts/check-module-boundaries.ts --error --module dental-imaging",
    "perf": "bun run tests/perf/run.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@better-auth/api-key": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "@hono/zod-openapi": "^0.18.0",
    "@hono/zod-validator": "^0.4.0",
    "@monobase/api-spec": "workspace:*",
    "@monobase/ceph-math": "workspace:*",
    "@onesignal/node-onesignal": "^5.2.1-beta1",
    "@scalar/hono-api-reference": "^0.9.16",
    "@vvo/tzdb": "^6.186.0",
    "better-auth": "^1.4.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.8",
    "hono": "^4.0.0",
    "i18n-iso-countries": "^7.14.0",
    "iso-639-1": "^3.1.5",
    "libphonenumber-js": "^1.12.24",
    "nodemailer": "^7.0.6",
    "pg": "^8.16.3",
    "pg-boss": "^10.3.2",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.7",
    "postmark": "^4.0.5",
    "prom-client": "^15.1.3",
    "stripe": "^19.1.0",
    "uuid": "^11.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@monobase/eslint-config": "workspace:*",
    "@monobase/typescript-config": "workspace:*",
    "@types/autocannon": "^7.12.7",
    "@types/bun": "latest",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.8.0",
    "msw": "^2.14.2",
    "nanoid": "^5.1.6",
    "typescript": "^5.7.0",
    "ws": "^8.18.3"
  }
}
