{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", "bunfig.toml"],
  "globalEnv": ["NODE_ENV", "CI", "DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".tanstack/**"]
    },
    "typecheck": {},
    "lint": {},
    "test": {
      "outputs": ["coverage/**"]
    },
    "generate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
