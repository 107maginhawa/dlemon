import "@typespec/http";
import "@typespec/rest";
import "@typespec/openapi";
import "../../../common/models.tsp";
import "../../../common/errors.tsp";
import "../../../common/pagination.tsp";
import "../../../common/security.tsp";
import "../../core/primitives.tsp";
import "../../core/terminology.tsp";

using TypeSpec.Http;
using TypeSpec.Rest;
using TypeSpec.OpenAPI;
using Healthcare.Core;
using Healthcare.Core.Terminology;

/**
 * Immunization Information System (IIS) / Immunization Registry module.
 *
 * Provides models and operations for bidirectional integration with state and
 * regional Immunization Information Systems (IIS), also known as immunization
 * registries. Supports submission of administered immunisations to the IIS,
 * bi-directional query for patient immunisation history, and clinical decision
 * support forecast retrieval. Aligned with the HL7 Version 2.5.1 IIS messaging
 * guide, the FHIR Immunisation IG, and CDC IIS Functional Standards.
 */
namespace Healthcare.Support.PublicHealth.ImmunizationRegistry;

// ---------------------------------------------------------------------------
// Enumerations
// ---------------------------------------------------------------------------

@doc("Status of an immunisation submission to the Immunization Information System.")
enum IISStatus {
  @doc("The submission has been queued but not yet sent to the IIS")
  pending,

  @doc("The HL7 VXU or FHIR immunisation resource has been transmitted to the IIS")
  submitted,

  @doc("The IIS accepted and incorporated the immunisation record")
  accepted,

  @doc("The IIS rejected the submission — check responseMessage for reason codes")
  rejected,

  @doc("The IIS determined this record is a duplicate of an existing entry")
  duplicate,
}

@doc("Status of an IIS query for a patient's immunisation history.")
enum IISQueryStatus {
  @doc("The query has been sent to the IIS and awaiting a response")
  submitted,

  @doc("The IIS returned immunisation records for the patient")
  responseReceived,

  @doc("The IIS found no records matching the patient demographics")
  noRecordFound,

  @doc("An error occurred during the query — may indicate connectivity or matching issues")
  error,
}

@doc("Clinical forecast status for a vaccine group, indicating the patient's immunisation status relative to the ACIP recommended schedule.")
enum ForecastStatus {
  @doc("A dose is due now based on the patient's age and immunisation history")
  dueNow,

  @doc("A dose was due in the past and the patient is behind schedule")
  overdue,

  @doc("The patient has serological evidence of immunity and no further doses are needed")
  immune,

  @doc("A clinical contraindication or precaution exists for this vaccine group")
  contraindicated,

  @doc("The vaccine is not currently recommended for this patient based on age, risk group, or other criteria")
  notRecommended,

  @doc("The patient has completed the recommended series for this vaccine group")
  complete,
}

// ---------------------------------------------------------------------------
// Supporting models
// ---------------------------------------------------------------------------

@doc("A clinical decision support forecast recommendation for a specific vaccine group, generated by the IIS or a CDS engine using the patient's immunisation history.")
model ForecastRecommendation {
  @doc("The vaccine group or antigen for which this forecast applies (CVX coded — e.g., 'MMR', 'DTaP', 'COVID-19')")
  vaccineGroup: CodeableConcept;

  @doc("Current immunisation forecast status for this vaccine group")
  forecastStatus: ForecastStatus;

  @doc("Earliest recommended date for the next dose based on minimum intervals")
  dueDate?: plainDate;

  @doc("Date by which the dose is considered overdue if not administered")
  overdueDate?: plainDate;

  @doc("Latest recommended date for the next dose based on maximum age or interval limits")
  latestDate?: plainDate;

  @doc("The recommended dose number in the series (e.g., 1, 2, 3)")
  doseNumber?: int32;
}

// ---------------------------------------------------------------------------
// Root models
// ---------------------------------------------------------------------------

@doc("A record of an immunisation submission sent to the state or regional Immunization Information System (IIS) following administration of a vaccine.")
model IISSubmission extends HealthcareBaseEntity {
  @doc("Reference to the Patient who received the immunisation")
  patient: Reference;

  @doc("Reference to the Immunization resource representing the administered vaccine dose")
  immunization: Reference;

  @doc("Reference to the Organisation (facility) submitting the immunisation record to the IIS")
  submittingFacility: Reference;

  @doc("Date and time the submission was sent to the IIS")
  submittedAt: utcDateTime;

  @doc("Current status of the submission in the IIS acknowledgement workflow")
  status: IISStatus;

  @doc("Human-readable response message or error code returned by the IIS in the ACK segment")
  responseMessage?: string;

  @doc("The IIS-assigned unique identifier for this immunisation record after successful acceptance")
  registryId?: string;

  @doc("The HL7 MSH-10 Message Control ID of the VXU message sent to the IIS")
  hl7MessageId?: string;
}

@doc("A record of a query sent to the Immunization Information System to retrieve a patient's complete immunisation history.")
model IISQuery extends HealthcareBaseEntity {
  @doc("Reference to the Patient whose immunisation history is being queried")
  patient: Reference;

  @doc("Date and time the query was sent to the IIS")
  queryDate: utcDateTime;

  @doc("Reference to the Practitioner or clinical system that initiated the query")
  queriedBy: Reference;

  @doc("Name or identifier of the IIS registry queried (e.g., 'California CAIR', 'Texas ImmTrac2')")
  registryQueried: string;

  @doc("Current status of the IIS query")
  status: IISQueryStatus;

  @doc("Number of immunisation records returned by the IIS in the query response")
  immunizationsReturned?: int32;

  @doc("Additional notes from the querying clinician or system regarding the query results")
  note?: string;
}

// ---------------------------------------------------------------------------
// Search parameters
// ---------------------------------------------------------------------------

@doc("Search parameters for IIS submission queries.")
model IISSubmissionSearchParams {
  @doc("Filter by patient reference ID") @query patient?: string;
  @doc("Filter by immunisation reference ID") @query immunization?: string;
  @doc("Filter by submitting facility reference ID") @query submittingFacility?: string;
  @doc("Filter by submission status") @query status?: IISStatus;
  @doc("Filter submissions sent on or after this date") @query submittedFrom?: utcDateTime;
  @doc("Filter submissions sent on or before this date") @query submittedTo?: utcDateTime;
  ...OffsetPaginationParams;
}

@doc("Search parameters for IIS query record queries.")
model IISQuerySearchParams {
  @doc("Filter by patient reference ID") @query patient?: string;
  @doc("Filter by querying practitioner reference ID") @query queriedBy?: string;
  @doc("Filter by registry queried (partial match)") @query registryQueried?: string;
  @doc("Filter by query status") @query status?: IISQueryStatus;
  @doc("Filter queries sent on or after this date") @query queriedFrom?: utcDateTime;
  @doc("Filter queries sent on or before this date") @query queriedTo?: utcDateTime;
  ...OffsetPaginationParams;
}

// ---------------------------------------------------------------------------
// Interfaces
// ---------------------------------------------------------------------------

@doc("IIS submission management — submit administered immunisation records to state and regional IIS registries and track acknowledgement status.")
@tag("Healthcare:Support")
@useAuth(bearerAuth)
@route("/public-health/iis/submissions")
interface IISSubmissionManagement {
  @doc("Create a new IIS submission record for an administered immunisation.")
  @operationId("createIISSubmission")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @post
  createIISSubmission(
    @body body: IISSubmission,
  ): {
    @statusCode statusCode: 201;
    @body result: IISSubmission;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve an IIS submission record by its logical ID.")
  @operationId("getIISSubmission")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @get
  @route("/{id}")
  getIISSubmission(
    @path @doc("IISSubmission logical ID") id: UUID,
  ): {
    @statusCode statusCode: 200;
    @body result: IISSubmission;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search IIS submission records by patient, immunisation, facility, status, or date range.")
  @operationId("searchIISSubmissions")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @get
  @route("/search")
  searchIISSubmissions(
    ...IISSubmissionSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<IISSubmission>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}

@doc("IIS query management — query Immunization Information Systems for patient immunisation history and retrieve clinical decision support forecasts.")
@tag("Healthcare:Support")
@useAuth(bearerAuth)
@route("/public-health/iis/queries")
interface IISQueryManagement {
  @doc("Initiate a new IIS query to retrieve a patient's immunisation history from the registry.")
  @operationId("createIISQuery")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @post
  createIISQuery(
    @body body: IISQuery,
  ): {
    @statusCode statusCode: 201;
    @body result: IISQuery;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve an IIS query record by its logical ID.")
  @operationId("getIISQuery")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @get
  @route("/{id}")
  getIISQuery(
    @path @doc("IISQuery logical ID") id: UUID,
  ): {
    @statusCode statusCode: 200;
    @body result: IISQuery;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search IIS query records by patient, clinician, registry, status, or date range.")
  @operationId("searchIISQueries")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @get
  @route("/search")
  searchIISQueries(
    ...IISQuerySearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<IISQuery>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve immunisation forecast recommendations for a patient from the IIS clinical decision support engine, based on the patient's age and vaccination history.")
  @operationId("getImmunizationForecast")
  @extension("x-security-required-roles", #["admin", "clinician"])
  @get
  @route("/forecast")
  getImmunizationForecast(
    @doc("Patient reference ID for whom to retrieve the forecast") @query patient: string,
    @doc("Registry to query for forecast recommendations") @query registry?: string,
  ): {
    @statusCode statusCode: 200;
    @body result: ForecastRecommendation[];
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}
