import "@typespec/http";
import "@typespec/rest";
import "@typespec/openapi";
import "../../../common/models.tsp";
import "../../../common/errors.tsp";
import "../../../common/pagination.tsp";
import "../../../common/security.tsp";
import "../../core/primitives.tsp";
import "../../core/terminology.tsp";

using TypeSpec.Http;
using TypeSpec.Rest;
using TypeSpec.OpenAPI;
using Healthcare.Core;
using Healthcare.Core.Terminology;

/**
 * Hospital Cost Accounting module.
 *
 * Provides models and operations for cost center management, cost allocation,
 * case-level costing, and general ledger export. Supports departmental
 * profitability analysis, DRG-based costing, and integration with downstream
 * financial systems through structured GL export workflows.
 */
namespace Healthcare.Administrative.Hospital.CostAccounting;

// ---------------------------------------------------------------------------
// Enumerations
// ---------------------------------------------------------------------------

@doc("Classification of a cost center by its financial role in the organization.")
enum CostCenterType {
  @doc("A cost center that directly generates patient care revenue")
  revenue,

  @doc("A cost center that incurs direct patient care expenses without billing")
  expense,

  @doc("A cost center that accumulates shared facility or support costs allocated to other centers")
  overhead,

  @doc("A cost center for general administrative and management functions")
  administrative,
}

@doc("Status of a case-level costing record.")
enum CostingStatus {
  @doc("The case cost has been estimated but not yet confirmed — charges and costs may still change")
  preliminary,

  @doc("The case cost has been finalized — all charges, costs, and payments have been reconciled")
  final,
}

@doc("Status of a General Ledger export batch.")
enum GLExportStatus {
  @doc("The GL export has been queued but entries have not yet been generated")
  pending,

  @doc("GL entries have been generated and are ready for review and export")
  generated,

  @doc("The GL file has been exported to the downstream financial system")
  exported,

  @doc("The exported GL entries have been reconciled against the financial system")
  reconciled,
}

// ---------------------------------------------------------------------------
// Supporting models
// ---------------------------------------------------------------------------

@doc("A line-item cost breakdown for a single category within a case costing record.")
model CostBreakdownItem {
  @doc("Cost category (e.g., 'Room and Board', 'Laboratory', 'Pharmacy', 'Surgery')")
  category: string;

  @doc("Detailed description of this cost item")
  description: string;

  @doc("Total charges generated by this category")
  charges: Money;

  @doc("Actual costs incurred for this category")
  costs: Money;

  @doc("Number of units or services included in this line item, if applicable")
  quantity?: int32;
}

@doc("A single General Ledger journal entry within a GL export batch.")
model GLEntry {
  @doc("Chart of accounts code for this GL entry")
  accountCode: string;

  @doc("Cost center code associated with this transaction")
  costCenter: string;

  @doc("Debit amount for this entry, if applicable")
  debit?: Money;

  @doc("Credit amount for this entry, if applicable")
  credit?: Money;

  @doc("Narrative description of this GL transaction")
  description: string;

  @doc("Source reference identifier linking this entry back to the originating charge or allocation")
  reference?: string;
}

@doc("Request body to trigger GL entry generation for an existing CostAllocation or CostCenter period.")
model GLGenerateRequest {
  @doc("Accounting period for which to generate GL entries")
  period: Period;

  @doc("Optional list of cost center references to limit the scope of GL generation")
  costCenters?: Reference[];
}

// ---------------------------------------------------------------------------
// Root models
// ---------------------------------------------------------------------------

@doc("A cost center representing an organizational unit for which costs and revenues are tracked separately.")
model CostCenter extends HealthcareBaseEntity {
  @doc("Unique alphanumeric code identifying this cost center in the chart of accounts")
  code: string;

  @doc("Human-readable name of this cost center")
  name: string;

  @doc("Reference to the department this cost center is associated with, if applicable")
  department?: Reference;

  @doc("Financial classification of this cost center")
  type: CostCenterType;

  @doc("Reference to a parent cost center for hierarchical reporting rollup")
  parentCostCenter?: Reference;

  @doc("Whether this cost center is currently active and accepting charge allocations")
  active: boolean;
}

@doc("A cost allocation record summarizing the distribution of direct, indirect, and overhead costs for a cost center over a defined accounting period.")
model CostAllocation extends HealthcareBaseEntity {
  @doc("Reference to the cost center for which this allocation was calculated")
  costCenter: Reference;

  @doc("Accounting period covered by this allocation")
  period: Period;

  @doc("Total direct costs charged directly to this cost center for the period")
  directCosts: Money;

  @doc("Indirect costs allocated from supporting departments")
  indirectCosts: Money;

  @doc("Overhead costs allocated based on the cost center's relative size or usage")
  overhead: Money;

  @doc("Total cost (directCosts + indirectCosts + overhead)")
  totalCost: Money;

  @doc("Total revenue generated by this cost center for the period, if applicable")
  revenueGenerated?: Money;

  @doc("Description of the allocation methodology used (e.g., 'step-down', 'direct apportionment')")
  allocationMethod?: string;

  @doc("Additional notes on this allocation — variance explanations, adjustments")
  note?: string;
}

@doc("A case-level cost record linking an inpatient or outpatient encounter to its aggregated charges, costs, payments, and itemized cost breakdown.")
model CaseCosting extends HealthcareBaseEntity {
  @doc("Reference to the encounter (visit) being costed")
  encounter: Reference;

  @doc("Reference to the patient — denormalized for reporting without encounter join")
  patient: Reference;

  @doc("Total gross charges generated for this encounter")
  totalCharges: Money;

  @doc("Total actual costs incurred for this encounter")
  totalCosts: Money;

  @doc("Total payments received or expected for this encounter")
  totalPayments?: Money;

  @doc("Net profit or loss for this encounter (totalPayments - totalCosts); negative indicates a loss")
  profitLoss?: Money;

  @doc("Itemized breakdown of charges and costs by care category")
  costBreakdown: CostBreakdownItem[];

  @doc("Diagnosis-Related Group code assigned to this inpatient stay, if applicable")
  drgCode?: string;

  @doc("Length of stay in whole days for inpatient encounters")
  los: int32;

  @doc("Current status of this case costing record")
  status: CostingStatus;
}

@doc("A General Ledger export batch covering a specific accounting period, containing journal entries ready for transmission to the financial system.")
model GLExport extends HealthcareBaseEntity {
  @doc("Accounting period covered by this GL export")
  period: Period;

  @doc("Current status of this GL export batch")
  status: GLExportStatus;

  @doc("Journal entries included in this export batch")
  entries: GLEntry[];

  @doc("Date and time the GL entries were generated")
  generatedAt: utcDateTime;

  @doc("Date and time the export file was transmitted to the financial system")
  exportedAt?: utcDateTime;
}

// ---------------------------------------------------------------------------
// Search parameters
// ---------------------------------------------------------------------------

@doc("Search parameters for cost centers.")
model CostCenterSearchParams {
  @doc("Filter by cost center code") @query code?: string;
  @doc("Filter by cost center type") @query type?: CostCenterType;
  @doc("Filter by department reference ID") @query department?: string;
  @doc("Filter by parent cost center reference ID") @query parentCostCenter?: string;
  @doc("Filter by active status") @query active?: boolean;
  @doc("Free-text search on cost center name") @query name?: string;
  ...OffsetPaginationParams;
}

@doc("Search parameters for cost allocations.")
model CostAllocationSearchParams {
  @doc("Filter by cost center reference ID") @query costCenter?: string;
  @doc("Filter by period start on or after this date") @query periodFrom?: utcDateTime;
  @doc("Filter by period end on or before this date") @query periodTo?: utcDateTime;
  @doc("Filter by allocation method keyword") @query allocationMethod?: string;
  ...OffsetPaginationParams;
}

@doc("Search parameters for case costing records.")
model CaseCostingSearchParams {
  @doc("Filter by encounter reference ID") @query encounter?: string;
  @doc("Filter by patient reference ID") @query patient?: string;
  @doc("Filter by DRG code") @query drgCode?: string;
  @doc("Filter by costing status") @query status?: CostingStatus;
  @doc("Filter by minimum length of stay") @query losMin?: int32;
  @doc("Filter by maximum length of stay") @query losMax?: int32;
  ...OffsetPaginationParams;
}

@doc("Search parameters for GL export batches.")
model GLExportSearchParams {
  @doc("Filter by GL export status") @query status?: GLExportStatus;
  @doc("Filter by period start on or after this date") @query periodFrom?: utcDateTime;
  @doc("Filter by period end on or before this date") @query periodTo?: utcDateTime;
  @doc("Filter exports generated at or after this date") @query generatedFrom?: utcDateTime;
  ...OffsetPaginationParams;
}

// ---------------------------------------------------------------------------
// Interfaces
// ---------------------------------------------------------------------------

@doc("Cost center management — maintain the organizational chart of cost centers used for departmental cost tracking and financial reporting.")
@tag("Healthcare:Administrative")
@useAuth(bearerAuth)
@route("/cost-accounting/cost-centers")
interface CostCenterManagement {
  @doc("Create a new cost center.")
  @operationId("createCostCenter")
  @extension("x-security-required-roles", #["admin", "biller"])
  @post
  createCostCenter(
    @body body: CostCenter,
  ): {
    @statusCode statusCode: 201;
    @body result: CostCenter;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a cost center by its logical ID.")
  @operationId("getCostCenter")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/{id}")
  getCostCenter(
    @path @doc("CostCenter logical ID") id: UUID,
  ): {
    @statusCode statusCode: 200;
    @body result: CostCenter;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Update a cost center — name, type, parent, or active status.")
  @operationId("updateCostCenter")
  @extension("x-security-required-roles", #["admin", "biller"])
  @put
  @route("/{id}")
  updateCostCenter(
    @path @doc("CostCenter logical ID") id: UUID,
    @body body: CostCenter,
  ): {
    @statusCode statusCode: 200;
    @body result: CostCenter;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Delete a cost center.")
  @operationId("deleteCostCenter")
  @extension("x-security-required-roles", #["admin"])
  @delete
  @route("/{id}")
  deleteCostCenter(
    @path @doc("CostCenter logical ID") id: UUID,
  ): {
    @statusCode statusCode: 204;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search cost centers by code, type, department, or active status.")
  @operationId("searchCostCenters")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/search")
  searchCostCenters(
    ...CostCenterSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<CostCenter>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}

@doc("Cost allocation management — record and query period-level cost distributions across cost centers.")
@tag("Healthcare:Administrative")
@useAuth(bearerAuth)
@route("/cost-accounting/allocations")
interface CostAllocationManagement {
  @doc("Create a new cost allocation record for a cost center and period.")
  @operationId("createCostAllocation")
  @extension("x-security-required-roles", #["admin", "biller"])
  @post
  createCostAllocation(
    @body body: CostAllocation,
  ): {
    @statusCode statusCode: 201;
    @body result: CostAllocation;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a cost allocation record by its logical ID.")
  @operationId("getCostAllocation")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/{id}")
  getCostAllocation(
    @path @doc("CostAllocation logical ID") id: UUID,
  ): {
    @statusCode statusCode: 200;
    @body result: CostAllocation;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Update a cost allocation record — adjust cost figures or allocation method.")
  @operationId("updateCostAllocation")
  @extension("x-security-required-roles", #["admin", "biller"])
  @put
  @route("/{id}")
  updateCostAllocation(
    @path @doc("CostAllocation logical ID") id: UUID,
    @body body: CostAllocation,
  ): {
    @statusCode statusCode: 200;
    @body result: CostAllocation;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Delete a cost allocation record.")
  @operationId("deleteCostAllocation")
  @extension("x-security-required-roles", #["admin"])
  @delete
  @route("/{id}")
  deleteCostAllocation(
    @path @doc("CostAllocation logical ID") id: UUID,
  ): {
    @statusCode statusCode: 204;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search cost allocations by cost center and accounting period.")
  @operationId("searchCostAllocations")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/search")
  searchCostAllocations(
    ...CostAllocationSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<CostAllocation>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}

@doc("Case costing management — encounter-level cost and revenue analysis including DRG-based costing and itemized cost breakdown.")
@tag("Healthcare:Administrative")
@useAuth(bearerAuth)
@route("/cost-accounting/case-costing")
interface CaseCostingManagement {
  @doc("Create a new case costing record for an encounter.")
  @operationId("createCaseCosting")
  @extension("x-security-required-roles", #["admin", "biller"])
  @post
  createCaseCosting(
    @body body: CaseCosting,
  ): {
    @statusCode statusCode: 201;
    @body result: CaseCosting;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a case costing record by its logical ID.")
  @operationId("getCaseCosting")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/{id}")
  getCaseCosting(
    @path @doc("CaseCosting logical ID") id: UUID,
  ): {
    @statusCode statusCode: 200;
    @body result: CaseCosting;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Update a case costing record — charges, costs, payments, breakdown, or status.")
  @operationId("updateCaseCosting")
  @extension("x-security-required-roles", #["admin", "biller"])
  @put
  @route("/{id}")
  updateCaseCosting(
    @path @doc("CaseCosting logical ID") id: UUID,
    @body body: CaseCosting,
  ): {
    @statusCode statusCode: 200;
    @body result: CaseCosting;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Delete a case costing record.")
  @operationId("deleteCaseCosting")
  @extension("x-security-required-roles", #["admin"])
  @delete
  @route("/{id}")
  deleteCaseCosting(
    @path @doc("CaseCosting logical ID") id: UUID,
  ): {
    @statusCode statusCode: 204;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search case costing records by encounter, patient, DRG, status, or length of stay.")
  @operationId("searchCaseCosting")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/search")
  searchCaseCosting(
    ...CaseCostingSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<CaseCosting>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Generate a case costing record automatically from encounter charges using the configured costing engine.")
  @operationId("generateCaseCosting")
  @extension("x-security-required-roles", #["admin", "biller"])
  @post
  @route("/generate")
  generateCaseCosting(
    @doc("Reference ID of the encounter for which to generate case costing") @query encounterId: UUID,
  ): {
    @statusCode statusCode: 201;
    @body result: CaseCosting;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}

@doc("General Ledger export management — generate, review, and track GL journal entry batches for transmission to the financial system.")
@tag("Healthcare:Administrative")
@useAuth(bearerAuth)
@route("/cost-accounting/gl-exports")
interface GLExportManagement {
  @doc("Create (trigger) a new GL export batch for a given accounting period.")
  @operationId("createGLExport")
  @extension("x-security-required-roles", #["admin", "biller"])
  @post
  createGLExport(
    @body body: GLGenerateRequest,
  ): {
    @statusCode statusCode: 201;
    @body result: GLExport;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a GL export batch by its logical ID, including all generated journal entries.")
  @operationId("getGLExport")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/{id}")
  getGLExport(
    @path @doc("GLExport logical ID") id: UUID,
  ): {
    @statusCode statusCode: 200;
    @body result: GLExport;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search GL export batches by status, period, or generation date.")
  @operationId("searchGLExports")
  @extension("x-security-required-roles", #["admin", "biller"])
  @get
  @route("/search")
  searchGLExports(
    ...GLExportSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<GLExport>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}
