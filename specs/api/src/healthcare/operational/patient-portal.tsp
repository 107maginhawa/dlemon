@doc("CRUD, send, and search operations for PatientIntakeForm resources.")
@tag("Healthcare:Operational")
@useAuth(bearerAuth)
interface PatientIntakeFormManagement {
  @doc("Create a new PatientIntakeForm record.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @post
  @operationId("createPatientIntakeForm")
  create(
    @body body: PatientIntakeForm,
  ): {
    @statusCode statusCode: 201;
    @body patientIntakeForm: PatientIntakeForm;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a single PatientIntakeForm by id.")
  @extension("x-security-required-roles", #["admin", "scheduler", "patient:owner"])
  @get
  @operationId("getPatientIntakeForm")
  @route("/{id}")
  get(
    @path id: string,
  ): {
    @statusCode statusCode: 200;
    @body patientIntakeForm: PatientIntakeForm;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Replace an existing PatientIntakeForm record.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @put
  @operationId("updatePatientIntakeForm")
  @route("/{id}")
  update(
    @path id: string,
    @body body: PatientIntakeForm,
  ): {
    @statusCode statusCode: 200;
    @body patientIntakeForm: PatientIntakeForm;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Delete a PatientIntakeForm by id.")
  @extension("x-security-required-roles", #["admin"])
  @delete
  @operationId("deletePatientIntakeForm")
  @route("/{id}")
  delete(
    @path id: string,
  ): {
    @statusCode statusCode: 204;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Send a patient intake form to the patient via the portal, setting the expiry deadline.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @post
  @operationId("sendPatientIntakeForm")
  @route("/{id}/send")
  send(
    @path id: string,
    @body body: SendIntakeFormRequest,
  ): {
    @statusCode statusCode: 200;
    @body patientIntakeForm: PatientIntakeForm;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiConflictResponse | ApiInternalServerErrorResponse;

  @doc("Search for PatientIntakeForm resources using filter parameters.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @get
  @operationId("searchPatientIntakeForms")
  @route("/search")
  search(
    ...PatientIntakeFormSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<PatientIntakeForm>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}
