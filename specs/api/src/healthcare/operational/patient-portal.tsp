import "@typespec/http";
import "@typespec/rest";
import "@typespec/openapi";
import "../../common/models.tsp";
import "../../common/errors.tsp";
import "../../common/pagination.tsp";
import "../../common/security.tsp";
import "../core/primitives.tsp";
import "../core/terminology.tsp";

using TypeSpec.Http;
using TypeSpec.Rest;
using TypeSpec.OpenAPI;
using Healthcare.Core;
using Healthcare.Core.Terminology;

/**
 * Healthcare Operational Patient Portal — self-service digital access for
 * patients including account management, online appointment booking, secure
 * messaging with providers, online payment processing, and pre-visit intake
 * form submission.
 */
namespace Healthcare.Operational.PatientPortal;

// ---------------------------------------------------------------------------
// Enumerations
// ---------------------------------------------------------------------------

@doc("The lifecycle status of a patient portal account.")
enum PortalAccountStatus {
  @doc("The account has been created but the patient has not yet completed registration")
  pending,

  @doc("The account is active and the patient can log in")
  active,

  @doc("The account has been temporarily locked (e.g., due to failed login attempts)")
  locked,

  @doc("The account has been permanently deactivated")
  deactivated,
}

@doc("The lifecycle status of an online booking request.")
enum OnlineBookingStatus {
  @doc("The booking request has been submitted and is awaiting staff review")
  pending,

  @doc("The booking request has been confirmed and an appointment created")
  confirmed,

  @doc("The booking request was declined by staff")
  declined,

  @doc("The booking request expired without being processed within the allowed window")
  expired,

  @doc("The booking request was cancelled by the patient or staff")
  cancelled,
}

@doc("The type of party that sent or is to receive a portal message.")
enum PortalSenderType {
  @doc("The message was sent by or is addressed to the patient")
  patient,

  @doc("The message was sent by or is addressed to a healthcare provider")
  provider,

  @doc("The message was generated by the system")
  system,
}

@doc("The category of a portal message to support routing and filtering.")
enum PortalMessageCategory {
  @doc("A general enquiry not fitting other categories")
  general,

  @doc("A message relating to a bill or financial matter")
  billing,

  @doc("A message relating to an appointment booking or cancellation")
  appointment,

  @doc("A message relating to a prescription or medication refill")
  prescription,

  @doc("A message delivering or enquiring about test results")
  results,

  @doc("A message relating to a referral to another provider")
  referral,
}

@doc("The payment status of a portal payment transaction.")
enum PortalPaymentStatus {
  @doc("The payment is being processed")
  pending,

  @doc("The payment was successfully processed")
  completed,

  @doc("The payment was declined or failed")
  failed,

  @doc("The payment has been refunded to the patient")
  refunded,
}

@doc("The lifecycle status of a patient intake form.")
enum IntakeFormStatus {
  @doc("The form has been sent to the patient and is awaiting completion")
  sent,

  @doc("The patient has started but not yet submitted the form")
  inProgress,

  @doc("The patient has completed and submitted the form")
  submitted,

  @doc("The form has expired without being completed")
  expired,
}

// ---------------------------------------------------------------------------
// Resource models
// ---------------------------------------------------------------------------

@doc("A patient portal account providing the patient with access to self-service digital health services.")
model PortalAccount extends HealthcareBaseEntity {
  @doc("The patient this portal account belongs to")
  patient: Reference;

  @doc("The email address used for portal login and communications")
  @maxLength(254)
  email: string;

  @doc("The current lifecycle status of the portal account")
  status: PortalAccountStatus;

  @doc("The date and time the account was first registered")
  registeredAt: utcDateTime;

  @doc("The date and time the patient last successfully logged in")
  lastLoginAt?: utcDateTime;

  @doc("Whether multi-factor authentication is enabled on this account")
  mfaEnabled?: boolean;

  @doc("The date and time the patient accepted the portal terms and conditions")
  termsAcceptedAt?: utcDateTime;
}

@doc("An online appointment booking request submitted by a patient through the patient portal.")
model OnlineBookingRequest extends HealthcareBaseEntity {
  @doc("The patient who submitted the booking request")
  patient: Reference;

  @doc("The type of appointment the patient is requesting")
  appointmentType?: CodeableConcept;

  @doc("The provider the patient prefers to see, if any")
  preferredProvider?: Reference;

  @doc("The patient's preferred date for the appointment")
  preferredDate?: plainDate;

  @doc("The patient's preferred time range (e.g., 'morning', 'afternoon', '09:00–11:00')")
  @maxLength(100)
  preferredTimeRange?: string;

  @doc("The patient's stated reason for the appointment")
  @maxLength(500)
  reason?: string;

  @doc("The current status of this booking request")
  status: OnlineBookingStatus;

  @doc("Reference to the confirmed appointment created from this booking request, if confirmed")
  confirmedAppointment?: Reference;
}

@doc("A secure message exchanged between a patient and provider through the patient portal.")
model PortalMessage extends HealthcareBaseEntity {
  @doc("The patient associated with this message thread")
  patient: Reference;

  @doc("The display name or identifier of the message sender")
  @maxLength(200)
  sender: string;

  @doc("Whether the sender is the patient, a provider, or the system")
  senderType: PortalSenderType;

  @doc("The display name or identifier of the message recipient")
  @maxLength(200)
  recipient: string;

  @doc("Whether the recipient is the patient, a provider, or the system")
  recipientType: PortalSenderType;

  @doc("The subject line of the message")
  @maxLength(300)
  subject: string;

  @doc("The full body text of the message")
  @maxLength(10000)
  body: string;

  @doc("The date and time the message was sent")
  sentAt: utcDateTime;

  @doc("The date and time the message was read by the recipient")
  readAt?: utcDateTime;

  @doc("The category of this message for routing and display purposes")
  category: PortalMessageCategory;

  @doc("Documents or files attached to this message")
  attachments?: Reference[];
}

@doc("A payment transaction initiated by a patient through the patient portal.")
model PortalPayment extends HealthcareBaseEntity {
  @doc("The patient who made this payment")
  patient: Reference;

  @doc("The monetary amount of the payment")
  amount: Money;

  @doc("The payment method used (e.g., 'credit_card', 'bank_transfer', 'apple_pay')")
  @maxLength(100)
  paymentMethod: string;

  @doc("The external transaction identifier from the payment gateway")
  @maxLength(200)
  transactionId?: string;

  @doc("The current status of the payment transaction")
  status: PortalPaymentStatus;

  @doc("The date and time the payment was processed")
  paidAt?: utcDateTime;

  @doc("Reference to the invoice or account this payment is applied against")
  invoiceReference?: Reference;
}

@doc("A pre-visit patient intake form sent through the portal for completion before an appointment.")
model PatientIntakeForm extends HealthcareBaseEntity {
  @doc("The patient this intake form is for")
  patient: Reference;

  @doc("Reference to the questionnaire template defining the form structure")
  questionnaire: Reference;

  @doc("The current lifecycle status of the intake form")
  status: IntakeFormStatus;

  @doc("The date and time the form was sent to the patient")
  sentAt: utcDateTime;

  @doc("The date and time the patient submitted the completed form")
  submittedAt?: utcDateTime;

  @doc("The date and time the form link expires if not completed")
  expiresAt?: utcDateTime;

  @doc("Reference to the QuestionnaireResponse resource containing the patient's answers")
  response?: Reference;
}

// ---------------------------------------------------------------------------
// Request models
// ---------------------------------------------------------------------------

@doc("Request body for confirming an online booking request and linking it to an appointment.")
model ConfirmBookingRequest {
  @doc("Reference to the appointment created as a result of this booking request")
  appointmentId: string;
}

@doc("Request body for declining an online booking request.")
model DeclineBookingRequest {
  @doc("The reason the booking request is being declined")
  @maxLength(500)
  reason: string;
}

@doc("Request body for sending a patient intake form.")
model SendIntakeFormRequest {
  @doc("The date and time the form link should expire")
  expiresAt: utcDateTime;
}

// ---------------------------------------------------------------------------
// Search params
// ---------------------------------------------------------------------------

@doc("Search parameters for PortalAccount resources.")
model PortalAccountSearchParams {
  @doc("Filter by patient reference id")
  @query patient?: string;

  @doc("Filter by account status")
  @query status?: PortalAccountStatus;

  @doc("Filter by email address (partial match)")
  @query email?: string;

  ...PaginationQuery;
}

@doc("Search parameters for PortalMessage resources.")
model PortalMessageSearchParams {
  @doc("Filter by patient reference id")
  @query patient?: string;

  @doc("Filter by message category")
  @query category?: PortalMessageCategory;

  @doc("Filter by sender type")
  @query senderType?: PortalSenderType;

  @doc("Filter by whether the message has been read")
  @query unread?: boolean;

  @doc("Filter messages sent on or after this date-time")
  @query sentFrom?: utcDateTime;

  @doc("Filter messages sent on or before this date-time")
  @query sentTo?: utcDateTime;

  ...PaginationQuery;
}

@doc("Search parameters for PortalPayment resources.")
model PortalPaymentSearchParams {
  @doc("Filter by patient reference id")
  @query patient?: string;

  @doc("Filter by payment status")
  @query status?: PortalPaymentStatus;

  @doc("Filter by invoice reference id")
  @query invoiceReference?: string;

  @doc("Filter payments made on or after this date-time")
  @query paidFrom?: utcDateTime;

  @doc("Filter payments made on or before this date-time")
  @query paidTo?: utcDateTime;

  ...PaginationQuery;
}

@doc("Search parameters for PatientIntakeForm resources.")
model PatientIntakeFormSearchParams {
  @doc("Filter by patient reference id")
  @query patient?: string;

  @doc("Filter by questionnaire reference id")
  @query questionnaire?: string;

  @doc("Filter by form status")
  @query status?: IntakeFormStatus;

  @doc("Filter forms sent on or after this date-time")
  @query sentFrom?: utcDateTime;

  @doc("Filter forms sent on or before this date-time")
  @query sentTo?: utcDateTime;

  ...PaginationQuery;
}

// ---------------------------------------------------------------------------
// Interfaces
// ---------------------------------------------------------------------------

@doc("CRUD and search operations for PortalAccount resources.")
@tag("Healthcare:Operational")
@useAuth(bearerAuth)
interface PortalAccountManagement {
  @doc("Create a new PortalAccount for a patient.")
  @extension("x-security-required-roles", #["admin", "scheduler", "patient:owner"])
  @post
  @operationId("createPortalAccount")
  create(
    @body body: PortalAccount,
  ): {
    @statusCode statusCode: 201;
    @body portalAccount: PortalAccount;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a single PortalAccount by id.")
  @extension("x-security-required-roles", #["admin", "scheduler", "patient:owner"])
  @get
  @operationId("getPortalAccount")
  @route("/{id}")
  get(
    @path id: string,
  ): {
    @statusCode statusCode: 200;
    @body portalAccount: PortalAccount;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Replace an existing PortalAccount.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @put
  @operationId("updatePortalAccount")
  @route("/{id}")
  update(
    @path id: string,
    @body body: PortalAccount,
  ): {
    @statusCode statusCode: 200;
    @body portalAccount: PortalAccount;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Partially update a PortalAccount (e.g., lock or deactivate the account).")
  @extension("x-security-required-roles", #["admin", "scheduler", "patient:owner"])
  @patch
  @operationId("patchPortalAccount")
  @route("/{id}")
  patch(
    @path id: string,
    @body body: Record<unknown>,
  ): {
    @statusCode statusCode: 200;
    @body portalAccount: PortalAccount;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Delete a PortalAccount by id.")
  @extension("x-security-required-roles", #["admin"])
  @delete
  @operationId("deletePortalAccount")
  @route("/{id}")
  delete(
    @path id: string,
  ): {
    @statusCode statusCode: 204;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Search for PortalAccount resources using filter parameters.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @get
  @operationId("searchPortalAccounts")
  @route("/search")
  search(
    ...PortalAccountSearchParams,
  ): {
    @statusCode statusCode: 200;
    @body result: PaginatedResponse<PortalAccount>;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;
}

@doc("CRUD, confirm, and decline operations for OnlineBookingRequest resources.")
@tag("Healthcare:Operational")
@useAuth(bearerAuth)
interface OnlineBookingManagement {
  @doc("Submit a new online booking request through the patient portal.")
  @extension("x-security-required-roles", #["admin", "scheduler", "patient:owner"])
  @post
  @operationId("createOnlineBookingRequest")
  create(
    @body body: OnlineBookingRequest,
  ): {
    @statusCode statusCode: 201;
    @body onlineBookingRequest: OnlineBookingRequest;
  } | ApiBadRequestResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Retrieve a single OnlineBookingRequest by id.")
  @extension("x-security-required-roles", #["admin", "scheduler", "patient:owner"])
  @get
  @operationId("getOnlineBookingRequest")
  @route("/{id}")
  get(
    @path id: string,
  ): {
    @statusCode statusCode: 200;
    @body onlineBookingRequest: OnlineBookingRequest;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Replace an existing OnlineBookingRequest.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @put
  @operationId("updateOnlineBookingRequest")
  @route("/{id}")
  update(
    @path id: string,
    @body body: OnlineBookingRequest,
  ): {
    @statusCode statusCode: 200;
    @body onlineBookingRequest: OnlineBookingRequest;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Delete an OnlineBookingRequest by id.")
  @extension("x-security-required-roles", #["admin"])
  @delete
  @operationId("deleteOnlineBookingRequest")
  @route("/{id}")
  delete(
    @path id: string,
  ): {
    @statusCode statusCode: 204;
  } | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiInternalServerErrorResponse;

  @doc("Confirm an online booking request and link it to the created appointment.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @post
  @operationId("confirmOnlineBookingRequest")
  @route("/{id}/confirm")
  confirm(
    @path id: string,
    @body body: ConfirmBookingRequest,
  ): {
    @statusCode statusCode: 200;
    @body onlineBookingRequest: OnlineBookingRequest;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiConflictResponse | ApiInternalServerErrorResponse;

  @doc("Decline an online booking request, notifying the patient.")
  @extension("x-security-required-roles", #["admin", "scheduler"])
  @post
  @operationId("declineOnlineBookingRequest")
  @route("/{id}/decline")
  decline(
    @path id: string,
    @body body: DeclineBookingRequest,
  ): {
    @statusCode statusCode: 200;
    @body onlineBookingRequest: OnlineBookingRequest;
  } | ApiBadRequestResponse | ApiNotFoundResponse | ApiUnauthorizedResponse | ApiForbiddenResponse | ApiConflictResponse | ApiInternalServerErrorResponse;
}

