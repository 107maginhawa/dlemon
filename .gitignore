.gemini-clipboard
.gstack/
.worktrees/

# Claude scheduled tasks
.claude/scheduled_tasks.lock

# Scratch/working prompt directories
docs/prompts-erase/

# Claude Code agent worktree scratch (transient)
.claude/worktrees/

# understand-anything knowledge graph.
# Policy (UA_KG_UPGRADE.md / U1): the graphs are COMMITTED so the AI's
# understanding of THIS codebase travels with the repo and freshness is
# PR-auditable (a diff can show "flow changed but its graph didn't"). The
# bulky derived caches (fingerprints, intermediate batch scratch) are NOT
# committed — they regenerate and would make every refresh an unreadable diff.
.understand-anything/fingerprints.json
.understand-anything/intermediate/
.understand-anything/tmp/
# Derived/transient overlays (regenerate from the committed graphs + working tree;
# contract-spine = generated contract-coverage index, diff-overlay = working-tree diff).
.understand-anything/contract-spine.json
.understand-anything/diff-overlay.json

# workflow-verification smoke venv (local Playwright/Firefox; never commit)
apps/dentalemon/tests/smoke/.venv/

# webwright craft scratch dirs (per-module; never commit)
apps/dentalemon/tests/smoke/.craft-*/

# root-level webwright craft scratch
.craft-*/

# Audit working scratch (19MB, regenerable) — not source (root only;
# unanchored pattern was also swallowing docs/aha/**/outputs/)
/outputs/

# AI brainstorm session scratch + Python Hypothesis cache
.superpowers/
.hypothesis/

# Per-developer agent/skill tooling (gstack) — machine-local, not team-shared.
# .claude/skills/design-taste-frontend is a symlink into .agents/skills.
.agents/
.claude/skills/design-taste-frontend
skills-lock.json

# Phase 0 coverage-ledger intermediate fragments (regenerable; assembled into coverage-ledger.json)
docs/testing/coverage/.ledger-parts/
.impeccable/
.env*
